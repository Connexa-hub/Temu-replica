# ====== CORE ======
PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/connexa_shop
CLIENT_BASE_URL=http://localhost:3000

# ====== AUTH ======
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# First admin bootstrap (used ONCE by the seed script, then disable/rotate)
ADMIN_BOOTSTRAP_EMAIL=admin@connexa.example
ADMIN_BOOTSTRAP_PASSWORD=change_me_now_minimum_12_chars

# ====== EMAIL (OTP / receipts) ======
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
MAIL_FROM_ADDRESS=no-reply@connexa.example
MAIL_FROM_NAME=Connexa

# ====== MONNIFY (primary gateway) ======
# Sandbox docs: https://developers.monnify.com
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_API_KEY=MK_TEST_xxxxxxxxxx
MONNIFY_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MONNIFY_CONTRACT_CODE=xxxxxxxxxx

# ====== PAYSTACK ======
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ====== FLUTTERWAVE ======
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# Set this in the Flutterwave dashboard under Settings > Webhooks ("Secret Hash" field) — your own
# random string, NOT the same as the encryption key above. Used for verbatim header comparison.
FLUTTERWAVE_SECRET_HASH=replace_with_a_random_string_you_choose
# Set this in your Flutterwave dashboard under Settings > Webhooks (a value YOU choose)
FLUTTERWAVE_SECRET_HASH=choose_a_long_random_string

# ====== STRIPE (optional, for international cards) ======
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ====== UPLOADS ======
# 'local' stores under /uploads (fine for dev/single-server); switch to 's3' for production
UPLOAD_DRIVER=local
MAX_UPLOAD_MB=8

# ====== RATE LIMITING ======
API_RATE_LIMIT_PER_15MIN=200
AUTH_RATE_LIMIT_PER_15MIN=30
