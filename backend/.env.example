# --- Premium E-Commerce Backend Configuration Envs ---
PORT=3000

# High-Security Admin Sign up Gatekey
# Anyone trying to register with administrator credentials or role must supply this exact token
ADMIN_SIGNUP_TOKEN=ADMIN_MASTER_SECRET_2026

# Production MongoDB Cluster Connection String 
# Examples: 
# - mongo://localhost:27017/shopdb (Local test instance)
# - mongodb+srv://username:password@cluster0.mongodb.net/shopdb (Production cluster)
# If left blank, the app gracefully falls back to secure local File JSON 'db.json'
MONGO_URI=

# --- PAYMENT INTEGRATION CLEARANCE KEYS ---
# Set these keys for live payment clearance in production
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder_key_secure_2026
STRIPE_SECRET_KEY=sk_test_placeholder_key_secure_2026

PAYPAL_CLIENT_ID=paypal_client_id_secure_2026
PAYPAL_CLIENT_SECRET=paypal_client_secret_secure_2026

FLUTTERWAVE_SECRET_KEY=FLWSECK_test_placeholder_key_secure_2026
PAYSTACK_SECRET_KEY=sk_test_paystack_placeholder_key_secure_2026
RAZORPAY_KEY_SECRET=rzp_test_placeholder_key_secure_2026
